{
  "name": "billing_software_textile",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5183 && electron .",
    "build:vite": "vite build",
    "build:electron": "electron-builder",
    "package": "npm run build:vite && npm run build:electron",
    "build": "npm run package",
    "rebuild-sqlite": "npx electron-rebuild -f -w sqlite3",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "Dhanalakshmi Textiles",
  "license": "ISC",
  "description": "Desktop Billing Software for Dhanalakshmi Textiles",
  "dependencies": {
    "lucide-react": "^0.479.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.dhanalakshmi.billing",
    "productName": "Dhanalakshmi Textiles Billing",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    }
  }
}
